# FastAPI Server Configuration
PORT=8000
HOST=0.0.0.0

# MongoDB Configuration
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=portfolio_db

# Security & JWT Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=super_secret_jwt_sign_key_for_dinesh_portfolio_12345
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin Credentials
ADMIN_USERNAME=admin
# bcrypt hash for "admin123" is: $2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36KQUS7gbe2sc3gQeG5G6Ky
# Change this for production!
ADMIN_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36KQUS7gbe2sc3gQeG5G6Ky
